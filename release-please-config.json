{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "include-component-in-tag": false,
      "changelog-path": "Changelog.md",
      "extra-files": [
        {
          "type": "toml",
          "path": "server/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "rust_client/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name=='throttle-server')].version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name=='throttle-client')].version"
        },
        {
          "type": "toml",
          "path": "uv.lock",
          "jsonpath": "$.package[?(@.name=='throttle-client')].version"
        }
      ]
    }
  }
}
